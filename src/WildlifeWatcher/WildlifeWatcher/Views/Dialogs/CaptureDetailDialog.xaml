<Window x:Class="WildlifeWatcher.Views.Dialogs.CaptureDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Detail" Width="800" Height="500"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="#F5F5F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Full image -->
        <Border Grid.Row="0" Background="Black">
            <Image x:Name="CaptureImage" Stretch="Uniform"/>
        </Border>

        <!-- Details panel -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: info + notes -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="14" FontWeight="Bold" Foreground="#2D5A27"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="ConfidenceTextBlock"
                               FontSize="11" Foreground="#666" Margin="0,2,0,2"/>
                    <TextBlock x:Name="AlternativesTextBlock"
                               FontSize="11" Foreground="#888" Margin="0,0,0,4"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="NotesBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="48" Padding="6,4" FontSize="12"
                             BorderBrush="#CCCCCC"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Width="120">
                    <Button Content="⤢ Full Size" Click="FullSize_Click"
                            Background="#555555" Foreground="White"
                            BorderThickness="0" Padding="10,6"
                            Cursor="Hand" FontSize="12" Margin="0,0,0,4"
                            ToolTip="Open image in default viewer at native resolution"/>
                    <Button x:Name="ToggleAnnotatedButton"
                            Content="View Annotated" Click="ToggleAnnotated_Click"
                            Background="#2D5A27" Foreground="White"
                            BorderThickness="0" Padding="10,6"
                            Cursor="Hand" FontSize="12" Margin="0,0,0,4"
                            Visibility="Collapsed"/>
                    <Button Content="Save Notes" Click="SaveNotes_Click"
                            Background="#2D5A27" Foreground="White"
                            BorderThickness="0" Padding="10,6"
                            Cursor="Hand" FontSize="12" Margin="0,0,0,4"/>
                    <Button Content="Delete" Click="Delete_Click"
                            Background="#C0392B" Foreground="White"
                            BorderThickness="0" Padding="10,6"
                            Cursor="Hand" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
