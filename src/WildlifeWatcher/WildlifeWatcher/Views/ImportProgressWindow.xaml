<Window x:Class="WildlifeWatcher.Views.ImportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importing Data" Height="180" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#F5F5F0"
        Closing="Window_Closing">
    <StackPanel Margin="24,20">
        <TextBlock Text="Importing Wildlife Watcher data…"
                   FontSize="14" FontWeight="Bold" Foreground="#2D5A27" Margin="0,0,0,12"/>
        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100"
                     Height="8" Foreground="#2D5A27" Background="#E0E0E0"/>
        <TextBlock x:Name="StatusText" FontSize="11" Foreground="#555"
                   TextWrapping="Wrap" Margin="0,6,0,0"/>
        <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#CC3333"
                   TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
        <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"
                HorizontalAlignment="Right" Margin="0,12,0,0" Padding="16,6"
                Background="#2D5A27" Foreground="White" BorderThickness="0"
                Cursor="Hand" Visibility="Collapsed"/>
    </StackPanel>
</Window>
