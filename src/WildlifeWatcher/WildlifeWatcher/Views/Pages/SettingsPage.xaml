<UserControl x:Class="WildlifeWatcher.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:WildlifeWatcher.Models"
      Background="#F5F5F0">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2D5A27"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="560">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="#2D5A27" Margin="0,0,0,8"/>

            <!-- ═══ Camera ═══ -->
            <TextBlock Text="Camera" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="RTSP URL" Style="{StaticResource Label}"/>
            <TextBox x:Name="RtspUrlBox" Text="{Binding RtspUrl, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Username" Style="{StaticResource Label}"/>
            <TextBox x:Name="RtspUsernameBox" Text="{Binding RtspUsername, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Password" Style="{StaticResource Label}"/>
            <PasswordBox x:Name="RtspPasswordBox" Padding="6,4"
                         BorderBrush="#CCCCCC" FontSize="12"/>

            <Button Content="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    Background="#2D5A27" Foreground="White"
                    BorderThickness="0" Padding="12,6"
                    Cursor="Hand" FontSize="12"
                    Margin="0,8,0,4" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding TestConnectionStatus}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="{Binding TestConnectionStatusColor}"/>

            <!-- ═══ Capture ═══ -->
            <TextBlock Text="Capture" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Cooldown after detection (seconds)" Style="{StaticResource Label}"/>
            <TextBlock Text="Suppresses AI calls for this many seconds after a species is saved. The camera still runs and POIs are still detected — only the API call is skipped. Prevents repeated alerts for the same animal." Style="{StaticResource Hint}"/>
            <TextBox Text="{Binding CooldownSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Per-species save cooldown (minutes)" Style="{StaticResource Label}"/>
            <TextBlock Text="If the same species was already captured within this window, the new capture is silently discarded — no file is written and no database record is created. Set to 0 to disable. Default: 5 minutes." Style="{StaticResource Hint}"/>
            <TextBox Text="{Binding SpeciesCooldownMinutes, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Frame sampling interval (seconds)" Style="{StaticResource Label}"/>
            <TextBlock Text="How often a frame is grabbed from the camera and analysed for motion. Independent of cooldown — the loop wakes up every N seconds regardless of whether a detection occurred." Style="{StaticResource Hint}"/>
            <TextBox Text="{Binding FrameIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Minimum confidence threshold (0.0 – 1.0)" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding MinConfidenceThreshold, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Pixel change threshold (5 = subtle … 50 = strong contrast)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding MotionPixelThreshold}"
                    Minimum="5" Maximum="50"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding MotionPixelThreshold, StringFormat={}{0}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding PixelThresholdAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <TextBlock Text="Background model alpha (0.01 slow … 0.20 fast)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding MotionBackgroundAlpha}"
                    Minimum="0.01" Maximum="0.20" TickFrequency="0.01"
                    IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding MotionBackgroundAlpha, StringFormat={}{0:F2}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding AlphaAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <!-- ═══ Location ═══ -->
            <TextBlock Text="Location" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>
            <TextBlock Text="Used for weather data paired with captures."
                       Style="{StaticResource Hint}"/>

            <DockPanel Margin="0,4,0,0">
                <Button DockPanel.Dock="Right" Content="Search"
                        Command="{Binding SearchLocationCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="12,4"
                        Cursor="Hand" FontSize="12" Margin="6,0,0,0"/>
                <TextBox Text="{Binding LocationQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"
                         Tag="City name or postcode…"/>
            </DockPanel>

            <TextBlock Text="{Binding LocationSearchStatus}"
                       FontSize="11" Foreground="#888" Margin="0,2,0,2"/>

            <ItemsControl ItemsSource="{Binding LocationResults}"
                          Visibility="{Binding HasLocationResults,
                                       Converter={StaticResource BoolToVisibleConverter}}"
                          Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,4" Cursor="Hand" Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectLocationCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="11" Foreground="#333" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Visibility="{Binding LocationName,
                                    Converter={StaticResource NullOrEmptyToCollapsedConverter}}"
                       Margin="0,4,0,8" FontSize="11" Foreground="#2D5A27">
                <Run Text="Current: "/>
                <Run Text="{Binding LocationName}"/>
            </TextBlock>

            <!-- ═══ Daylight Detection ═══ -->
            <TextBlock Text="Daylight Detection" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <CheckBox IsChecked="{Binding EnableDaylightDetectionOnly}"
                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Only detect animals during daylight hours"
                           FontSize="12" Foreground="#444" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Background model training continues at all times."
                       Style="{StaticResource Hint}"/>

            <!-- Location warning (shown when toggle is on but no location is set) -->
            <Border Padding="8,6"
                    Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                    Margin="0,4,0,4"
                    Visibility="{Binding ShowDaylightLocationWarning,
                                 Converter={StaticResource BoolToVisibleConverter}}">
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#6D4C00">
                    No location set — using 06:00–20:00 fallback.
                    Set a location above for accurate sunrise/sunset times.
                </TextBlock>
            </Border>

            <Grid Margin="0,4,0,0"
                  IsEnabled="{Binding EnableDaylightDetectionOnly}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sunrise offset -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sunrise offset (minutes)" Style="{StaticResource Label}"/>
                    <TextBlock Text="Negative = before sunrise, positive = after. Default: −30."
                               Style="{StaticResource Hint}"/>
                    <TextBox Text="{Binding SunriseOffsetMinutes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Field}"/>
                </StackPanel>

                <!-- Sunset offset -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Sunset offset (minutes)" Style="{StaticResource Label}"/>
                    <TextBlock Text="Positive = after sunset, negative = before. Default: +30."
                               Style="{StaticResource Hint}"/>
                    <TextBox Text="{Binding SunsetOffsetMinutes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Field}"/>
                </StackPanel>
            </Grid>

            <!-- ═══ Data & Storage ═══ -->
            <TextBlock Text="Data &amp; Storage" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Captures directory" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding CapturesDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Command="{Binding BrowseCaptureFolderCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="10,4"
                        Cursor="Hand" FontSize="12" Margin="6,0,0,0"/>
                <Button Grid.Column="2" Content="📁 Open"
                        Command="{Binding OpenCaptureFolderCommand}"
                        Background="Transparent" Foreground="#2D5A27"
                        BorderThickness="1" BorderBrush="#2D5A27"
                        Padding="10,4" Cursor="Hand" FontSize="12" Margin="4,0,0,0"/>
            </Grid>

            <TextBlock Text="Database file" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Command="{Binding BrowseDatabaseCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="10,4"
                        Cursor="Hand" FontSize="12" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Text="Leave blank to use default location (%AppData%\WildlifeWatcher\wildlife.db)"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,6"/>

            <!-- Backup & Restore -->
            <TextBlock Text="Backup &amp; Restore" Style="{StaticResource Label}"
                       FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBlock Text="Export or import your settings, database, and captures. API keys and camera credentials are not included."
                       Style="{StaticResource Hint}"/>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                <Button Content="Export Data…"
                        Command="{Binding ExportDataCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="12,6"
                        Cursor="Hand" FontSize="12"/>
                <Button Content="Import Data…"
                        Command="{Binding ImportDataCommand}"
                        Background="#1A6B8A" Foreground="White"
                        BorderThickness="0" Padding="12,6"
                        Cursor="Hand" FontSize="12" Margin="8,0,0,0"/>
            </StackPanel>

            <ProgressBar Value="{Binding ExportImportProgress}"
                         Visibility="{Binding IsExportImportBusy, Converter={StaticResource BoolToVisibleConverter}}"
                         Height="6" Margin="0,4,0,4"
                         Foreground="#2D5A27" Background="#E0E0E0"/>

            <TextBlock Text="{Binding ExportImportStatus}"
                       FontSize="11" Foreground="#555" Margin="0,2,0,6"
                       TextWrapping="Wrap"/>

            <!-- ═══ Point of Interest ═══ -->
            <TextBlock Text="Point of Interest" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <CheckBox Content="Enable POI extraction (send cropped hotspots to AI instead of full frame)"
                      IsChecked="{Binding EnablePoiExtraction}"
                      FontSize="12" Foreground="#444" Margin="0,4,0,4"/>

            <CheckBox Content="Save POI debug images alongside captures"
                      IsChecked="{Binding SavePoiDebugImages}"
                      FontSize="12" Foreground="#444" Margin="0,4,0,4"/>

            <TextBlock Text="POI sensitivity (0 = conservative, 1 = aggressive)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding PoiSensitivity}"
                    Minimum="0" Maximum="1"
                    TickFrequency="0.01" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding PoiSensitivity, StringFormat={}{0:F2}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding PoiSensitivityAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <!-- ═══ AI ═══ -->
            <TextBlock Text="AI Recognition" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Provider" Style="{StaticResource Label}"/>
            <ComboBox ItemsSource="{Binding AiProviders}"
                      SelectedItem="{Binding AiProvider}"
                      Padding="6,4" FontSize="12"/>
            <TextBlock Text="Restart the app after changing provider for the new selection to take effect."
                       FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,6"/>

            <!-- Claude section -->
            <StackPanel x:Name="ClaudeSection">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AiProvider}" Value="{x:Static models:AiProvider.Gemini}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AiProvider}" Value="{x:Static models:AiProvider.LocalOnly}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Claude model" Style="{StaticResource Label}"/>
                <TextBox Text="{Binding ClaudeModel, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <TextBlock Text="Anthropic API key" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="ApiKeyBox" Padding="6,4"
                             BorderBrush="#CCCCCC" FontSize="12"/>
            </StackPanel>

            <!-- Gemini section -->
            <StackPanel x:Name="GeminiSection">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AiProvider}" Value="{x:Static models:AiProvider.Gemini}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Gemini model" Style="{StaticResource Label}"/>
                <TextBox Text="{Binding GeminiModel, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <TextBlock Text="Google AI API key" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="GeminiApiKeyBox" Padding="6,4"
                             BorderBrush="#CCCCCC" FontSize="12"/>
            </StackPanel>

            <!-- ═══ Motion Zones ═══ -->
            <TextBlock Text="Motion Zones" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,8"
                Text="Draw rectangles to restrict detection to those areas only. Leave empty to use the full frame."/>

            <Button Content="Capture Camera Snapshot"
                    Command="{Binding CaptureZoneBackgroundCommand}"
                    Background="#2D5A27" Foreground="White" BorderThickness="0"
                    Padding="12,6" Cursor="Hand" FontSize="12"
                    HorizontalAlignment="Left" Margin="0,0,0,8"/>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="#111111"
                    Margin="0,0,0,4">
                <Grid Width="560" Height="315">
                    <Image Stretch="Uniform"
                           Source="{Binding ZoneEditorBackground,
                                    Converter={StaticResource BytesToBitmapConverter}}"/>
                    <!-- Zone overlays -->
                    <ItemsControl ItemsSource="{Binding MotionZones}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="560" Height="315" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"  Value="{Binding CanvasLeft}"/>
                                <Setter Property="Canvas.Top"   Value="{Binding CanvasTop}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Rectangle Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                                               Stroke="#00FF88" StrokeThickness="2" Fill="#2200FF88"/>
                                    <TextBlock Text="{Binding Index}" Foreground="#00FF88"
                                               FontWeight="Bold" FontSize="12" Margin="4,2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Remove buttons (separate, hit-testable layer) -->
                    <ItemsControl ItemsSource="{Binding MotionZones}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="560" Height="315" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"  Value="{Binding CanvasLeft}"/>
                                <Setter Property="Canvas.Top"   Value="{Binding CanvasTop}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="×" FontSize="11" Padding="3,0"
                                        Background="Transparent" Foreground="#00FF88"
                                        BorderThickness="0" Cursor="Hand"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Command="{Binding DataContext.RemoveZoneCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Drawing overlay — separate canvas, not owned by ItemsControl -->
                    <Canvas x:Name="ZoneDrawCanvas" Width="560" Height="315"
                            Background="Transparent"
                            MouseLeftButtonDown="ZoneCanvas_MouseDown"
                            MouseMove="ZoneCanvas_MouseMove"
                            MouseLeftButtonUp="ZoneCanvas_MouseUp"/>
                </Grid>
            </Border>

            <TextBlock Text="Click and drag on the image above to add a zone."
                       FontSize="10" Foreground="#888" Margin="0,2,0,8"/>

            <Button Content="Clear All Zones"
                    Command="{Binding ClearZonesCommand}"
                    Background="Transparent" Foreground="#CC3333"
                    BorderBrush="#CC3333" BorderThickness="1"
                    Padding="10,4" Cursor="Hand" FontSize="12"
                    HorizontalAlignment="Left" Margin="0,0,0,4"/>

            <!-- ═══ Updates ═══ -->
            <TextBlock Text="Updates" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                <Button Content="Check for Updates"
                        Command="{Binding CheckForUpdatesCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="12,6"
                        Cursor="Hand" FontSize="12"/>
                <Button Content="Install Update"
                        Command="{Binding InstallUpdateCommand}"
                        Visibility="{Binding IsUpdateReadyToInstall, Converter={StaticResource BoolToVisibleConverter}}"
                        Background="#1A6B8A" Foreground="White"
                        BorderThickness="0" Padding="12,6"
                        Cursor="Hand" FontSize="12" Margin="8,0,0,0"/>
                <Button Content="Force Reinstall Latest"
                        Command="{Binding ForceUpdateCommand}"
                        Background="Transparent" Foreground="#888"
                        BorderBrush="#CCCCCC" BorderThickness="1" Padding="12,6"
                        Cursor="Hand" FontSize="12" Margin="8,0,0,0"
                        ToolTip="Download and install the latest GitHub release regardless of version"/>
            </StackPanel>

            <TextBlock Text="{Binding UpdateCheckStatus}"
                       FontSize="11" Foreground="#555" Margin="0,2,0,2"
                       TextWrapping="Wrap"/>

            <ProgressBar Value="{Binding InstallProgress}"
                         Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibleConverter}}"
                         Height="6" Margin="0,4,0,4"
                         Foreground="#2D5A27" Background="#E0E0E0"/>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,24">
                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        Cursor="Hand" FontSize="13" FontWeight="Bold"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="12" Foreground="#2D5A27"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
