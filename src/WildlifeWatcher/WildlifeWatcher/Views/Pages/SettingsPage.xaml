<UserControl x:Class="WildlifeWatcher.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F0">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2D5A27"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="560">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="#2D5A27" Margin="0,0,0,8"/>

            <!-- ═══ Camera ═══ -->
            <TextBlock Text="Camera" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="RTSP URL" Style="{StaticResource Label}"/>
            <TextBox x:Name="RtspUrlBox" Text="{Binding RtspUrl, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Username" Style="{StaticResource Label}"/>
            <TextBox x:Name="RtspUsernameBox" Text="{Binding RtspUsername, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Password" Style="{StaticResource Label}"/>
            <PasswordBox x:Name="RtspPasswordBox" Padding="6,4"
                         BorderBrush="#CCCCCC" FontSize="12"/>

            <Button Content="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    Background="#2D5A27" Foreground="White"
                    BorderThickness="0" Padding="12,6"
                    Cursor="Hand" FontSize="12"
                    Margin="0,8,0,4" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding TestConnectionStatus}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="{Binding TestConnectionStatusColor}"/>

            <!-- ═══ Capture ═══ -->
            <TextBlock Text="Capture" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Cooldown between captures (seconds)" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding CooldownSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Frame extraction interval (seconds)" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding FrameIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Minimum confidence threshold (0.0 – 1.0)" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding MinConfidenceThreshold, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Motion sensitivity (0 = low, 1 = high)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding MotionSensitivity}"
                    Minimum="0" Maximum="1"
                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding MotionSensitivity, StringFormat={}{0:F1}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding SensitivityAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <TextBlock Text="Pixel change threshold (5 = subtle … 50 = strong contrast)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding MotionPixelThreshold}"
                    Minimum="5" Maximum="50"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding MotionPixelThreshold, StringFormat={}{0}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding PixelThresholdAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <TextBlock Text="Background model alpha (0.01 slow … 0.20 fast)" Style="{StaticResource Label}"/>
            <Slider Value="{Binding MotionBackgroundAlpha}"
                    Minimum="0.01" Maximum="0.20" TickFrequency="0.01"
                    IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                    Margin="0,4,0,0"/>
            <TextBlock Text="{Binding MotionBackgroundAlpha, StringFormat={}{0:F2}}"
                       FontSize="11" Foreground="#777" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding AlphaAdvice}"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Margin="0,2,0,6"/>

            <!-- ═══ Data & Storage ═══ -->
            <TextBlock Text="Data &amp; Storage" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Captures directory" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding CapturesDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Command="{Binding BrowseCaptureFolderCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="10,4"
                        Cursor="Hand" FontSize="12" Margin="6,0,0,0"/>
                <Button Grid.Column="2" Content="📁 Open"
                        Command="{Binding OpenCaptureFolderCommand}"
                        Background="Transparent" Foreground="#2D5A27"
                        BorderThickness="1" BorderBrush="#2D5A27"
                        Padding="10,4" Cursor="Hand" FontSize="12" Margin="4,0,0,0"/>
            </Grid>

            <TextBlock Text="Database file" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Field}"/>
                <Button Grid.Column="1" Content="Browse…"
                        Command="{Binding BrowseDatabaseCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="10,4"
                        Cursor="Hand" FontSize="12" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Text="Leave blank to use default location (%AppData%\WildlifeWatcher\wildlife.db)"
                       FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,6"/>

            <!-- ═══ Point of Interest ═══ -->
            <TextBlock Text="Point of Interest" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <CheckBox Content="Enable POI extraction (send cropped hotspots to AI instead of full frame)"
                      IsChecked="{Binding EnablePoiExtraction}"
                      FontSize="12" Foreground="#444" Margin="0,4,0,4"/>

            <CheckBox Content="Save POI debug images alongside captures"
                      IsChecked="{Binding SavePoiDebugImages}"
                      FontSize="12" Foreground="#444" Margin="0,4,0,4"/>

            <!-- ═══ AI ═══ -->
            <TextBlock Text="AI Recognition" Style="{StaticResource SectionHeader}"/>
            <Separator Background="#DDDDDD" Margin="0,0,0,8"/>

            <TextBlock Text="Provider" Style="{StaticResource Label}"/>
            <ComboBox ItemsSource="{Binding AiProviders}"
                      SelectedItem="{Binding AiProvider}"
                      Padding="6,4" FontSize="12"/>

            <TextBlock Text="Claude model" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding ClaudeModel, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Field}"/>

            <TextBlock Text="Anthropic API key" Style="{StaticResource Label}"/>
            <PasswordBox x:Name="ApiKeyBox" Padding="6,4"
                         BorderBrush="#CCCCCC" FontSize="12"/>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,24">
                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Background="#2D5A27" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        Cursor="Hand" FontSize="13" FontWeight="Bold"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="12" Foreground="#2D5A27"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
