<UserControl x:Class="WildlifeWatcher.Views.Pages.LiveViewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Row 0: main content (video + detection panel) ══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Col 0: Video area + training bar + status bar -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- VideoView: never collapsed — destroying HWND breaks LibVLC.
                     WPF content placed inside renders via LibVLCSharp's ForegroundWindow
                     overlay which sits ON TOP of the native HWND (no airspace issue). -->
                <vlc:VideoView x:Name="VideoViewControl"
                               Grid.Row="0"
                               MediaPlayer="{Binding MediaPlayer}"
                               Background="Black">
                    <Grid>
                        <!-- Black overlay covers white HWND when not connected; collapses when streaming -->
                        <Grid Background="Black"
                              Visibility="{Binding IsConnected, Converter={StaticResource BoolToCollapsedConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No camera connected"
                                           Foreground="#888888" FontSize="18"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Configure camera in Settings, then click Connect."
                                           Foreground="#555555" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Burst progress bar — bottom-left of video, visible during burst -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                Margin="12,0,0,12"
                                Background="#CC0D1A0D" CornerRadius="4" Padding="8,5"
                                Visibility="{Binding IsBurstActive,
                                             Converter={StaticResource BoolToVisibleConverter}}">
                            <StackPanel Orientation="Vertical" Width="160">
                                <TextBlock Text="{Binding BurstProgressText}"
                                           Foreground="#88FF88" FontSize="11"
                                           FontFamily="Consolas" Margin="0,0,0,4"/>
                                <ProgressBar Value="{Binding BurstProgress}"
                                             Minimum="0" Maximum="1" Height="5"
                                             Foreground="#4CAF50" Background="#1A3A1A"/>
                            </StackPanel>
                        </Border>

                        <!-- POI overlay — fixed 1600×900 canvas scaled via Viewbox.
                             Stretch=Uniform matches LibVLC's own aspect-ratio-preserving render,
                             so the overlay tiles exactly over the visible video pixels. -->
                        <Viewbox Stretch="Uniform" IsHitTestVisible="False">
                            <ItemsControl ItemsSource="{Binding PoiOverlays}"
                                          Width="1600" Height="900">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1600" Height="900"
                                                Background="Transparent"
                                                IsHitTestVisible="False"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding CanvasTop}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Rectangle Width="{Binding CanvasWidth}"
                                                       Height="{Binding CanvasHeight}"
                                                       Stroke="#00FF88" StrokeThickness="3"
                                                       Fill="Transparent"/>
                                            <Border Background="#CC1E2A1E"
                                                    VerticalAlignment="Top"
                                                    HorizontalAlignment="Left"
                                                    Padding="5,2">
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="#00FF88"
                                                           FontSize="20"
                                                           FontFamily="Consolas"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Viewbox>
                    </Grid>
                </vlc:VideoView>

                <!-- Training bar — Row 1, collapses when training is complete -->
                <Border Grid.Row="1" Background="#162416" Padding="8,5"
                        Visibility="{Binding IsTrainingComplete,
                                     Converter={StaticResource BoolToCollapsedConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding TrainingStatusText}"
                                   Foreground="#AABBAA" FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <ProgressBar Grid.Column="1" Value="{Binding TrainingProgress}"
                                     Minimum="0" Maximum="1" Height="6"
                                     VerticalAlignment="Center"
                                     Foreground="#4CAF50" Background="#2A3A2A"/>
                        <TextBlock Grid.Column="2" Text="{Binding TrainingTimeLeftText}"
                                   Foreground="#778877" FontSize="11" VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <!-- Skip training button -->
                        <Button Grid.Column="4"
                                Content="⏭ Skip"
                                Command="{Binding SkipTrainingCommand}"
                                Background="Transparent" Foreground="#AABBAA"
                                BorderThickness="0" Padding="8,2"
                                Cursor="Hand" FontSize="11" Margin="0,0,4,0"
                                ToolTip="Skip training and begin AI analysis immediately"/>
                        <!-- Retrain button (during training) -->
                        <Button Grid.Column="5"
                                Content="↺ Retrain"
                                Command="{Binding RetrainCommand}"
                                Background="Transparent" Foreground="#AABBAA"
                                BorderThickness="0" Padding="8,2"
                                Cursor="Hand" FontSize="11"
                                ToolTip="Discard current model and retrain from scratch"/>
                    </Grid>
                </Border>

                <!-- Status bar — Row 2 -->
                <Border Grid.Row="2" Background="#1E2A1E" Padding="10,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status dot -->
                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#666666"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#CCDDCC" FontSize="12"/>
                        </StackPanel>

                        <!-- Volume control -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="Vol" Foreground="#889988" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Value="{Binding Volume}" Minimum="0" Maximum="100"
                                    Width="70" VerticalAlignment="Center"
                                    ToolTip="{Binding Volume, StringFormat=Volume: {0}%}"/>
                        </StackPanel>

                        <!-- Load local video file (debug) -->
                        <Button Grid.Column="3"
                                Content="🎬 Load File"
                                Command="{Binding LoadVideoFileCommand}"
                                Background="Transparent" Foreground="#AABBAA"
                                BorderThickness="0" Padding="8,4"
                                Cursor="Hand" FontSize="11" Margin="0,0,6,0"
                                ToolTip="Open a local video file for debug playback"/>

                        <!-- Open captures folder -->
                        <Button Grid.Column="4"
                                Content="📁 Captures"
                                Command="{Binding OpenCaptureFolderCommand}"
                                Background="Transparent" Foreground="#AABBAA"
                                BorderThickness="0" Padding="8,4"
                                Cursor="Hand" FontSize="11" Margin="0,0,6,0"/>

                        <!-- Retrain (visible when connected, training complete) -->
                        <Button Grid.Column="5"
                                Content="↺ Retrain"
                                Command="{Binding RetrainCommand}"
                                Background="Transparent" Foreground="#AABBAA"
                                BorderThickness="0" Padding="8,4"
                                Cursor="Hand" FontSize="11" Margin="0,0,6,0"
                                ToolTip="Discard background model and retrain from scratch"
                                Visibility="{Binding IsConnected,
                                             Converter={StaticResource BoolToVisibleConverter}}"/>

                        <!-- Connect / Disconnect -->
                        <Button Grid.Column="6"
                                Content="{Binding ConnectionButtonText}"
                                Command="{Binding ToggleConnectionCommand}"
                                Background="#2D5A27" Foreground="White"
                                BorderThickness="0" Padding="12,4"
                                Cursor="Hand" FontSize="12"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Col 1: Splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#2D2D2D"/>

            <!-- Col 2: Detection panel -->
            <Border Grid.Column="2" Background="#1E1E1E">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#252525" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Recent Detections"
                                       Foreground="White" FontWeight="Bold" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVisibleConverter}}">
                                <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Analyzing..." Foreground="#AAAAAA" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DaylightStatusText}"
                                       FontSize="11" Foreground="#E65100" TextWrapping="Wrap"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding DaylightStatusText,
                                                    Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                            <TextBlock Text="{Binding DaylightFallbackText}"
                                       FontSize="11" Foreground="#8D6E00" TextWrapping="Wrap"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding DaylightFallbackText,
                                                    Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Detection list -->
                    <ScrollViewer DockPanel.Dock="Bottom" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <TextBlock Text="No detections yet."
                                       Foreground="#555555" FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top" Margin="0,24,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentDetections.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding RecentDetections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="8,8,8,0" Background="#252525"
                                                CornerRadius="4" Padding="8" Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.OpenDetectionCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <Image Height="100" Stretch="UniformToFill"
                                                       Source="{Binding ThumbnailBytes, Converter={StaticResource BytesToBitmapConverter}}"
                                                       Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Result.CommonName}"
                                                           Foreground="White" FontWeight="Bold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Result.ScientificName}"
                                                           Foreground="#888888" FontSize="10" FontStyle="Italic"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#2D5A27"
                                                            CornerRadius="2" Padding="4,2"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Foreground="White" FontSize="10"
                                                                   Text="{Binding Result.Confidence, StringFormat={}{0:P0}}"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DetectedAt, StringFormat={}{0:HH:mm:ss}}"
                                                               Foreground="#555555" FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ══ Row 1: Recognition log panel (collapsible) ══ -->
        <Expander Grid.Row="1"
                  Header="Recognition Log"
                  Background="#111111"
                  Foreground="#AAAAAA"
                  BorderThickness="0,1,0,0"
                  BorderBrush="#333333"
                  MaxHeight="180">
            <Expander.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="#889988"
                               FontSize="11" FontFamily="Consolas" Padding="4,2"/>
                </DataTemplate>
            </Expander.HeaderTemplate>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#111111">
                <ItemsControl ItemsSource="{Binding LogEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas" FontSize="11" Padding="8,1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#778877"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWarningOrAbove}" Value="True">
                                                <Setter Property="Foreground" Value="#FF8844"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}, Mode=OneTime}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Level, Mode=OneTime}" FontWeight="Bold"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Message, Mode=OneTime}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Expander>
    </Grid>
</UserControl>
