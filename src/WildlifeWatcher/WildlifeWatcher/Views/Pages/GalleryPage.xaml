<UserControl x:Class="WildlifeWatcher.Views.Pages.GalleryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F0">

    <DockPanel>

        <!-- ════ Persistent top bar: Species / Calendar toggle ════ -->
        <Border DockPanel.Dock="Top" Background="White" Padding="8,8"
                BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Species" Command="{Binding ShowSpeciesListCommand}"
                        Padding="10,4" FontSize="11" Cursor="Hand" Margin="0,0,4,0"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsShowingCalendarView}" Value="False">
                                    <Setter Property="Background" Value="#2D5A27"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#2D5A27"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Calendar" Command="{Binding ShowCalendarCommand}"
                        Padding="10,4" FontSize="11" Cursor="Hand"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsShowingCalendarView}" Value="True">
                                    <Setter Property="Background" Value="#2D5A27"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#2D5A27"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- ════ View panels (overlapping via Visibility) ════ -->
        <Grid>

            <!-- ══ Species list view ══ -->
            <DockPanel Visibility="{Binding IsShowingSpeciesList,
                                   Converter={StaticResource BoolToVisibleConverter}}">

                <!-- Toolbar: sort, reset, search -->
                <Border DockPanel.Dock="Top" Background="White" Padding="16,8"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sort buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Name ▲"
                                    Command="{Binding SortCommand}" CommandParameter="NameAZ"
                                    Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,0,4,0"
                                    BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortMode}" Value="NameAZ">
                                                <Setter Property="Background" Value="#2D5A27"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#2D5A27"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Latin ▲"
                                    Command="{Binding SortCommand}" CommandParameter="LatinNameAZ"
                                    Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,0,4,0"
                                    BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortMode}" Value="LatinNameAZ">
                                                <Setter Property="Background" Value="#2D5A27"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#2D5A27"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Latest ▼"
                                    Command="{Binding SortCommand}" CommandParameter="LatestCapture"
                                    Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,0,4,0"
                                    BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortMode}" Value="LatestCapture">
                                                <Setter Property="Background" Value="#2D5A27"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#2D5A27"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Count ▼"
                                    Command="{Binding SortCommand}" CommandParameter="TotalCaptures"
                                    Padding="8,4" FontSize="11" Cursor="Hand"
                                    BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortMode}" Value="TotalCaptures">
                                                <Setter Property="Background" Value="#2D5A27"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#2D5A27"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Refresh photos button + status -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Button Content="↺ Refresh Photos"
                                    Command="{Binding RefreshSpeciesPhotosCommand}"
                                    IsEnabled="{Binding IsNotRefreshingPhotos}"
                                    Background="#2D5A27" Foreground="White"
                                    BorderThickness="0" Padding="10,5"
                                    Cursor="Hand" FontSize="12" Margin="0,0,6,0"
                                    ToolTip="Re-fetch reference photos from iNaturalist for all species"/>
                            <TextBlock Text="{Binding RefreshStatusText}"
                                       FontSize="11" Foreground="#555"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding RefreshStatusText, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                            <Button Content="🗑 Reset Gallery"
                                    Command="{Binding ResetGalleryCommand}"
                                    Background="#C0392B" Foreground="White"
                                    BorderThickness="0" Padding="10,5"
                                    Cursor="Hand" FontSize="12"
                                    ToolTip="Delete all captures and start fresh"/>
                        </StackPanel>
                        <TextBox Grid.Column="2"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="8,5" FontSize="12"
                                 VerticalAlignment="Center"
                                 BorderBrush="#CCCCCC"/>
                    </Grid>
                </Border>

                <!-- Empty state -->
                <TextBlock DockPanel.Dock="Top"
                           Text="No captures yet. Connect a camera and start watching!"
                           FontSize="14" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredSpecies.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Species grid -->
                <ListBox ItemsSource="{Binding FilteredSpecies}" Margin="16,12"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Single"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="180" Margin="8" Background="White"
                                    CornerRadius="6" Cursor="Hand"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenSpeciesCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Image Height="120" Stretch="UniformToFill"
                                           Source="{Binding PreviewImage}"
                                           ClipToBounds="True">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PreviewImagePath}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <StackPanel Margin="10,8">
                                        <TextBlock Text="{Binding Summary.CommonName}"
                                                   FontWeight="Bold" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary.ScientificName}"
                                                   FontStyle="Italic" FontSize="10"
                                                   Foreground="#888"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CaptureCount, StringFormat={}{0} capture(s)}"
                                                   FontSize="10" Foreground="#2D5A27" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding LastSeenLabel}"
                                                   FontSize="10" Foreground="#888"/>
                                        <TextBlock Text="{Binding FirstSeenLabel}"
                                                   FontSize="10" Foreground="#888"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ══ Species detail view ══ -->
            <DockPanel Visibility="{Binding IsShowingSpeciesDetail,
                                   Converter={StaticResource BoolToVisibleConverter}}">

                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="White" Padding="16,10"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="← Back" Command="{Binding BackCommand}"
                                Background="Transparent" Foreground="#2D5A27"
                                BorderThickness="0" Padding="0,0,16,0"
                                Cursor="Hand" FontSize="13"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedSpeciesName}"
                                       FontSize="20" FontWeight="Bold" Foreground="#2D5A27"/>
                            <TextBlock Text="{Binding SelectedSpeciesScientificName}"
                                       FontStyle="Italic" FontSize="12" Foreground="#888"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="2" Content="Select"
                                      IsChecked="{Binding IsSelectionMode, Mode=TwoWay}"
                                      Background="Transparent" Foreground="#2D5A27"
                                      BorderBrush="#2D5A27" BorderThickness="1"
                                      Padding="10,4" FontSize="11" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Batch action bar (visible in selection mode) -->
                <Border DockPanel.Dock="Top"
                        Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibleConverter}}"
                        Background="#FFF8E1" Padding="16,6"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} selected}"
                                   FontSize="12" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Delete Selected" Command="{Binding BatchDeleteCommand}"
                                Background="#C0392B" Foreground="White" BorderThickness="0"
                                Padding="10,5" FontSize="12" Cursor="Hand" Margin="0,0,8,0"/>
                        <Button Content="Reassign Selected" Command="{Binding BatchReassignCommand}"
                                Background="#555555" Foreground="White" BorderThickness="0"
                                Padding="10,5" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Day filter bar -->
                <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="16,8"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Filter by day:" FontSize="12" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableFilterYears}"
                                  SelectedItem="{Binding FilterYear, Mode=TwoWay}"
                                  Width="70" FontSize="12" Margin="0,0,4,0"
                                  VerticalContentAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableFilterMonths}"
                                  SelectedItem="{Binding FilterMonth, Mode=TwoWay}"
                                  Width="46" FontSize="12" Margin="0,0,4,0"
                                  VerticalContentAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableFilterDays}"
                                  SelectedItem="{Binding FilterDay, Mode=TwoWay}"
                                  Width="46" FontSize="12" Margin="0,0,12,0"
                                  VerticalContentAlignment="Center"/>
                        <Button Content="Filter" Command="{Binding FilterByDayCommand}"
                                Background="#2D5A27" Foreground="White" BorderThickness="0"
                                Padding="10,4" FontSize="12" Cursor="Hand" Margin="0,0,8,0"/>
                        <Button Content="Show All" Command="{Binding ShowAllCapturesCommand}"
                                Background="#555555" Foreground="White" BorderThickness="0"
                                Padding="10,4" FontSize="12" Cursor="Hand"
                                Visibility="{Binding IsFilteredByDay,
                                             Converter={StaticResource BoolToVisibleConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Loading indicator footer — shows while auto-loading more captures on scroll -->
                <Border DockPanel.Dock="Bottom" Background="White" Padding="0,8"
                        BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingMoreCaptures}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasMoreCaptures}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock HorizontalAlignment="Center" FontSize="11" Foreground="#888">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"
                                        Value="{Binding RemainingCaptureCount,
                                                StringFormat={}{0} more capture(s) — scroll down to load}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoadingMoreCaptures}" Value="True">
                                        <Setter Property="Text" Value="Loading…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Capture grid -->
                <ListBox x:Name="CapturesListBox"
                         ScrollViewer.ScrollChanged="OnCapturesScrollChanged"
                         ItemsSource="{Binding SelectedCaptures}" Margin="16,12"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Single"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="160" Margin="6" Background="White"
                                    CornerRadius="4" Cursor="Hand"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCaptureCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Grid>
                                        <Image Height="110" Stretch="UniformToFill"
                                               Source="{Binding ThumbnailSource}"
                                               ClipToBounds="True"/>
                                        <!-- Selection checkmark overlay -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                                                Width="22" Height="22" CornerRadius="11"
                                                Visibility="{Binding DataContext.IsSelectionMode,
                                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                                             Converter={StaticResource BoolToVisibleConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#AAFFFFFF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#2D5A27"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding IsSelected,
                                                                    Converter={StaticResource BoolToVisibleConverter}}"/>
                                        </Border>
                                    </Grid>
                                    <StackPanel Margin="8,4">
                                        <TextBlock Text="{Binding TimeLabel}"
                                                   FontSize="10" Foreground="#444"/>
                                        <TextBlock Text="{Binding ConfidenceLabel}"
                                                   FontSize="10" Foreground="#2D5A27"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ══ Calendar view ══ -->
            <DockPanel Visibility="{Binding IsShowingCalendarView,
                                   Converter={StaticResource BoolToVisibleConverter}}">

                <!-- Month navigation -->
                <Border DockPanel.Dock="Top" Background="White" Padding="16,10"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="‹" Command="{Binding NavigateCalendarBackCommand}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#CCCCCC"
                                Padding="8,4" FontSize="14" Cursor="Hand" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CalendarMonthLabel}"
                                   FontSize="16" FontWeight="Bold" Foreground="#2D5A27"
                                   VerticalAlignment="Center" Margin="4,0" MinWidth="160"
                                   TextAlignment="Center"/>
                        <Button Content="›" Command="{Binding NavigateCalendarForwardCommand}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#CCCCCC"
                                Padding="8,4" FontSize="14" Cursor="Hand" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Day-of-week headers (Mon–Sun) -->
                <UniformGrid DockPanel.Dock="Top" Columns="7" Background="#E8F0E8">
                    <TextBlock Text="Mon" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Tue" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Wed" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Thu" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Fri" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Sat" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                    <TextBlock Text="Sun" TextAlignment="Center" FontSize="11" FontWeight="Bold"
                               Foreground="#2D5A27" Padding="4,6"/>
                </UniformGrid>

                <!-- Calendar grid -->
                <ItemsControl ItemsSource="{Binding CalendarDays}" Margin="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" MinHeight="60" Margin="1"
                                    BorderBrush="#DDDDDD" BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectDateCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <!-- Today ring / day content — hidden for blank offset cells -->
                                <Border BorderThickness="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#2D5A27"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBlank}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <!-- Subtle accent bar at bottom — opacity encodes capture density -->
                                        <Rectangle DockPanel.Dock="Bottom" Height="3"
                                                   Fill="#2D5A27" Opacity="{Binding HeatOpacity}"/>
                                        <StackPanel Margin="4,3,4,3">
                                            <TextBlock Text="{Binding DayNumber,
                                                              Converter={StaticResource ZeroToEmptyStringConverter}}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#222"/>
                                            <!-- Weather condition -->
                                            <TextBlock Text="{Binding WeatherLabel}"
                                                       FontSize="9" Foreground="#444" TextWrapping="Wrap"
                                                       Visibility="{Binding HasWeather,
                                                                    Converter={StaticResource BoolToVisibleConverter}}"/>
                                            <!-- Temperature -->
                                            <TextBlock Text="{Binding TemperatureLabel}"
                                                       FontSize="9" Foreground="#333"
                                                       Visibility="{Binding HasTemperature,
                                                                    Converter={StaticResource BoolToVisibleConverter}}"/>
                                            <!-- Precipitation -->
                                            <TextBlock Text="{Binding PrecipLabel}"
                                                       FontSize="9" Foreground="#333"
                                                       Visibility="{Binding HasPrecip,
                                                                    Converter={StaticResource BoolToVisibleConverter}}"/>
                                            <!-- Sunrise / Sunset on one line -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasSunTimes,
                                                                     Converter={StaticResource BoolToVisibleConverter}}">
                                                <TextBlock Text="{Binding SunriseLabel}"
                                                           FontSize="9" Foreground="#333" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding SunsetLabel}"
                                                           FontSize="9" Foreground="#333"/>
                                            </StackPanel>
                                            <!-- Shot count — shown last -->
                                            <TextBlock Text="{Binding ShotCountLabel}"
                                                       FontSize="9" FontWeight="SemiBold" Foreground="#2D5A27"
                                                       Visibility="{Binding HasShots,
                                                                    Converter={StaticResource BoolToVisibleConverter}}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
