<Window x:Class="WildlifeWatcher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WildlifeWatcher.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCDDCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D4A2D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Update banner -->
            <RowDefinition Height="*"/>     <!-- Main content  -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Update banner (spans full width, visible when update is available) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibleConverter}}"
                Background="#FF8C00" Padding="12,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Update Now"
                        Command="{Binding ApplyUpdateCommand}"
                        Background="White" Foreground="#FF8C00"
                        BorderThickness="0" Padding="12,4"
                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                        Margin="8,0,0,0"/>
                <ProgressBar DockPanel.Dock="Right" Width="120" Minimum="0" Maximum="100"
                             Value="{Binding UpdateProgress}"
                             Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVisibleConverter}}"
                             Height="16" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding UpdateBannerText}"
                           VerticalAlignment="Center" Foreground="White"
                           FontSize="13" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- Left navigation rail -->
        <StackPanel Grid.Row="1" Grid.Column="0" Background="#1E2A1E" VerticalAlignment="Stretch">
            <TextBlock Text="Wildlife Watcher" Foreground="White" FontSize="13" FontWeight="Bold"
                       Margin="16,24,16,32" TextWrapping="Wrap" HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <Button Content="Live View"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{x:Static vm:AppPage.LiveView}"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="Gallery"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{x:Static vm:AppPage.Gallery}"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="Settings"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{x:Static vm:AppPage.Settings}"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="Detection Settings"
                    Command="{Binding OpenDetectionSettingsCommand}"
                    Style="{StaticResource NavButtonStyle}"/>
        </StackPanel>

        <!-- Main content area -->
        <ContentControl x:Name="PageContentControl" Grid.Row="1" Grid.Column="1"/>
    </Grid>

</Window>
