<Application x:Class="WildlifeWatcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WildlifeWatcher.Converters">
    <Application.Resources>
        <converters:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
        <converters:BytesToBitmapConverter x:Key="BytesToBitmapConverter"/>
        <converters:FilePathToImageConverter x:Key="FilePathToImageConverter"/>
        <converters:NullOrEmptyToCollapsedConverter x:Key="NullOrEmptyToCollapsedConverter"/>
        <!-- NullToCollapsedConverter: for nullable value types (e.g. DateTime?) -->
        <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <!-- Calendar converters (Phase 6) -->
        <converters:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
        <converters:ZeroToEmptyStringConverter x:Key="ZeroToEmptyStringConverter"/>
        <converters:HeightThresholdToVisibilityConverter x:Key="HeightThresholdConverter"/>

        <!-- Inverse: true → Visible (for IsAnalyzing indicator) -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibleConverter"/>
    </Application.Resources>
</Application>
